# ─── Database (Local Development) ───────────────────────────────────────────
# For local dev, use TCP connection to your local/Cloud SQL Auth Proxy
SQL_HOST=localhost
SQL_PORT=5432
SQL_USER=raja
SQL_PASSWORD=your_password_here
SQL_DB_NAME=raja_aset

# For Cloud Run production, SQL_HOST is set automatically via gcloud deploy:
# SQL_HOST=/cloudsql/PROJECT_ID:asia-southeast1:raja-db-instance

# ─── Auth ────────────────────────────────────────────────────────────────────
# Set to "true" ONLY for local dev to bypass Firebase token check
DEV_AUTH_BYPASS=true

# ─── AI (Xiaomi MiMo) ────────────────────────────────────────────────────────
MIMO_API_KEY=your_mimo_api_key_here

# ─── App URL (Cloud Run will set this automatically) ─────────────────────────
APP_URL=http://localhost:3000
